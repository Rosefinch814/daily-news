# Codex is the default AI provider and reuses the local `codex login` session.
# Verify it with `codex login status`; provider/model settings live in config/pipeline.yaml.

# Optional legacy Claude adapter only; daily generation does not depend on it.
# CLAUDE_COMMAND=claude -p

# Supabase is optional for local dry-runs. Use a server-side/secret key only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public browser key for anonymous feedback inserts. Never put the service role key here.
SUPABASE_ANON_KEY=

# Local owner-only feedback token. Used only for FEEDBACK_MODE=owner and digest-feedback.
# Never commit the real value.
OWNER_FEEDBACK_TOKEN=

# Optional behavior knobs.
DAILY_NEWS_FETCH_TIMEOUT_SECONDS=20
DAILY_NEWS_AI_TIMEOUT_SECONDS=300
